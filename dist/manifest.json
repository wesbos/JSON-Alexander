{
  "manifest_version": 3,
  "name": "JSON Alexander",
  "version": "1.1.0",
  "description": "Believe it or not, George formats JSON",
  "browser_specific_settings": {
    "gecko": {
      "id": "json-alexander@local"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-script.js", "pointer-32.png", "content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
